{
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/rss.xml",
      "destination": "/api/index.ts"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/index.ts"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}

